        ADDRESS            = Springer.addr,
        BOOKTITLE          = {Advances in {Petri} Nets 1991},
        EDITOR             = {Rozenberg, Grzegorz},
        PAGES              = {48--57},
        PUBLISHER          = Springer,
        SERIES             = LNCS,
        TITLE              = {The Complexity of Testing Equivalence of Transition Sequences},
        VOLUME             = {524},
        YEAR               = 1991,
  ISSN =         {0302-9743},
  ISBN =         {978-3-540-54398-5},
  xdoi =          {10.1007/BFb0019968},
  abstract =     {By [Best 89] and [Best, Devillers 88] a semantics for
                  place/transition nets has been defined on equivalence
                  classes of firing sequences induced by the exchange
                  relation (two transitions can be exchanged if they are
                  concurrently enabled).  This semantics preserves the
                  causal dependences between transitions.  For the
                  equivalence relation we show: Given a place/transition
                  net N and two firing sequences u, v in F(N), the
                  question u equivalent to v is NP-hard.  For a corresponding
                  equivalence relation on processes (or partially ordered
                  multisets) the test of equivalence will remain NP-hard.},
  url =          {https://link.springer.com/openurl?genre=article&issn=0302-9743&volume=524&spage=48},
  keywords =     {Causality/partial order theory of concurrency;
                  Analysis and synthesis, structure and behaviour of nets;
                  Net-based semantical, logical and algebraic calculi},
}

