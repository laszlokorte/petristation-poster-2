@InProceedings{Koehler+09k,
  author =   {K{\"o}hler-Bu{\ss}meier, Michael and Heitmann, Frank},
  title =   {On Defining Safeness for Object Nets},
  editor = {Czaja, L.  and Szczuka, M.},
  booktitle =  {Proceedings of the International Workshop
     on Concurrency, Specification, and Programming, CS{\&}P'2009 (Volume 1)},
  publisher =   {Warsaw University},
  year =  {2009},
  pages  = {265--276},
  abstract = {In this paper we discuss the concept of safeness for Elementary
Object Nets (EOS). Object nets are Petri nets which have Petri nets as
tokens - an approach known as the nets-within-nets paradigm. Object
nets are called elementary if the net system has a two levelled structure.
The well known p/t nets can be considered as a special case of EOS.
For p/t nets the concept of safeness means that there is at most one
token on each place. Since Object Nets have nested markings there are
different possibilities to generalise this idea for EOS. In this paper we
define different variants of EOS safeness, discuss their relationships and
show that they all coincide for p/t-like EOS.},
  url =   {http://csp2009.mimuw.edu.pl/proc.php}
}

