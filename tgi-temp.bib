@InCollection{Koehler+09g,
  author={K{\"o}hler-Bu{\ss}meier, Michael and Moldt, Daniel and Wester-Ebbinghaus, Matthias},
  title={A Formal Model for Organisational Structures Behind Process-Aware Information Systems},
  abstract={We present a formal model for the organisation of
                  process-aware information systems. Our approach
                  focuses on the structures "behind" business
                  processes, like e.g. team formation and
                  coordination. Our Petri net based model directly
                  integrates organisational concepts like roles, teams
                  etc. -- allowing an alignment of business and
                  IT. The benefit of this modelling overhead is that
                  business reorganisation processes are carried out as
                  formal model transformations. Additionally, the
                  automated mapping of our models to multi-agent
                  systems -- in the spirit of the model driven
                  architecture idea -- is directly supported by
                  our approach.},
  crossref ={Jensen+-e-09},
  pages={98--115},
  year = 2009
}

