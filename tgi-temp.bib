@inproceedings{Jantzen+91,
 Abstract = {It was shown by the authors (1987) (see PN-Newsletter 27, p. 69)
 that all terminal Petri net languages can be obtained from general context-free sets
by complete cancellation of substrings from the Dyck set with one pair of parentheses,
the so-called Dyck_1-reduction. The authors generalize this characterization by
showing that linear context-free languages suffice and that the Dyck set can be
replaced by a simpler bounded language. In proving this the authors obtain a new
